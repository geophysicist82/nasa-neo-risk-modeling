    s=100,
    label='Top Anomalies'
)

plt.title("Top 20 Anomalies Highlighted in Log-Scaled Space")
plt.xlabel("log(Velocity)")
plt.ylabel("log(Miss Distance)")
plt.legend()
plt.show()



